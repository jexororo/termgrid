{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri/capabilities.schema.json",
  "identifier": "default",
  "description": "Default capabilities for TermGrid",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit"
  ]
}
